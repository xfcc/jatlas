{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./dist-electron",
    "rootDir": ".",
    "types": ["node", "electron"],
    "resolveJsonModule": true
  },
  "include": ["electron/**/*.ts", "shared/**/*.ts", "core/**/*.ts"]
}
