# PostgreSQL Database URL (intranet / local instance)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# Emby Server Configuration
EMBY_SERVER_URL="http://YOUR_EMBY_SERVER_IP:8096"
EMBY_API_KEY="YOUR_EMBY_API_KEY"

# JATLAS Admin Password
ADMIN_PASSWORD="YOUR_ADMIN_PASSWORD"

# Absolute path to PostgreSQL command-line tools.
# If these variables are not set, the application will attempt to use 'pg_dump' and 'psql' from the system's PATH.
# Example for Homebrew on macOS: PG_DUMP_PATH=/opt/homebrew/bin/pg_dump
PG_DUMP_PATH=
PSQL_PATH=
