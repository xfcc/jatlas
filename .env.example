# SQLite Database URL (desktop default)
DATABASE_URL="file:./jatlas.db"

# Emby Server Configuration
EMBY_SERVER_URL="http://YOUR_EMBY_SERVER_IP:8096"
EMBY_API_KEY="YOUR_EMBY_API_KEY"

# JATLAS Admin Password
ADMIN_PASSWORD="YOUR_ADMIN_PASSWORD"

# Legacy PostgreSQL migration helpers (optional, only used for migration scripts)
PG_DUMP_PATH=
PSQL_PATH=
